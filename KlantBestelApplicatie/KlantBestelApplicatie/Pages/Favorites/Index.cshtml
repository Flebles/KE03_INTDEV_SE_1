@page
@model KlantBestelApplicatie.Pages.Favorites.IndexModel
@{
    ViewData["Title"] = "Favorieten";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-1">Favorieten</h1>
        <p class="text-muted mb-0">Je opgeslagen producten.</p>
    </div>
</div>

@if (!Model.FavoriteProducts.Any())
{
    <div class="alert alert-info">
        Geen favorieten toegevoegd.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var product in Model.FavoriteProducts)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <!-- a direct link from a favorited item to it's details page on the image -->
                    <a asp-page="/Products/Details" asp-route-id="@product.Id">
                        <img src="@product.PrimaryImage" alt="@product.Name" class="card-img-top product-card-image" />
                    </a>

                    <div class="card-body d-flex flex-column">
                        <!-- direct link to details on the item's name text -->
                        <a asp-page="/Products/Details"
                           asp-route-id="@product.Id"
                           class="text-decoration-none text-dark">
                            <h2 class="h5 card-title">@product.Name</h2>
                        </a>

                        <p class="fw-semibold text-primary mb-3">@product.Price.ToString("C")</p>

                        <!-- add to cart and remove from favs buttons -->
                        <div class="mt-auto d-flex flex-wrap gap-2">
                            <form method="post" asp-page-handler="AddToCart" asp-route-id="@product.Id">
                                <button type="submit" class="btn btn-success btn-sm">
                                    Voeg toe aan winkelwagen
                                </button>
                            </form>

                            <form method="post" asp-page-handler="Remove" asp-route-id="@product.Id">
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    Verwijder
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
@inject KlantBestelApplicatie.Services.FavoritesService FavoritesService
@inject KlantBestelApplicatie.Services.ShoppingCartService ShoppingCartService

<!DOCTYPE html>
<html lang="nl">

<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - KlantBestelApplicatie
    </title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />
</head>

<body>

    <header class="border-bottom bg-white sticky-top">

        <nav class="navbar navbar-expand-lg px-3 py-3 navbar-shop">

            <a asp-page="/Index"
               class="navbar-brand fw-bold logo-text">
                MATRIX INC
            </a>

            <form asp-page="/Index"
                  method="get"
                  class="search-bar mx-auto">

                <div class="input-group">

                    <input type="search" name="search" class="form-control" placeholder="Zoek producten" />

                    <button class="btn btn-outline-secondary" type="submit">🔍</button>

                </div>

            </form>

            <div class="d-flex gap-2">

                <a asp-page="/Favorites/Index"
                   class="btn btn-outline-danger">
                    Favorieten (@FavoritesService.Count)
                </a>

                <a asp-page="/Account/Index"
                   class="btn btn-outline-primary">
                    Account
                </a>

                <a asp-page="/Cart/Index"
                   class="btn btn-outline-success">
                    Winkelwagen (@ShoppingCartService.TotalQuantity)
                </a>

            </div>

        </nav>

    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted">
        <div class="container">
            <!-- Privacy page has been deleted, but will serve as a placeholder for now -->
            <!-- i lied its still there lol -->
            &copy; 2026 - Matrix Inc. - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>